{
  "version": "1.1.0",
  "name": "速度系统",
  "combatModel": "ATB半实时自动战斗",
  "tick": {
    "ticksPerSecond": 10,
    "tickSeconds": 0.1
  },
  "atb": {
    "max": 100,
    "coefficient": 0.1,
    "gainPerTick": "SPD * 0.1",
    "overflow": true
  },
  "attributes": [
    {
      "id": "speed",
      "abbr": "SPD",
      "cn": "行动速度",
      "purpose": "决定ATB增长、先手和行动频率"
    },
    {
      "id": "attackSpeed",
      "abbr": "ASP",
      "cn": "攻击速度",
      "purpose": "决定普攻间隔",
      "formula": "1 / ASP"
    },
    {
      "id": "castSpeed",
      "abbr": "CSP",
      "cn": "施法速度",
      "purpose": "决定主动技能施法时间",
      "formula": "baseCastTime / CSP"
    }
  ],
  "defaultBehavior": {
    "basicAttack": "单位ATB满后，若主动技能条件不满足，则进行普攻；普攻间隔由ASP约束。",
    "activeSkill": "单位ATB满后，若能量、冷却、AI条件满足，则开始施法；施法完成后结算。",
    "passive": "被动不占用ATB，按触发条件生效。"
  },
  "statusInteraction": {
    "freeze": {
      "speedMultiplier": 0,
      "pauseCast": true,
      "pauseAttackTimer": true
    },
    "stun": {
      "canAct": false,
      "pauseAtbGain": false
    },
    "slow": {
      "speedMultiplier": 0.6
    },
    "shock": {
      "attackSpeedMultiplier": 0.85
    }
  },
  "designNotes": [
    "固定顺序会让自动战斗变成回合制，不能支持高速流和先手控制。",
    "SPD、ASP、CSP必须拆开，避免一个速度属性同时支配所有行为导致数值失控。",
    "速度词条是Build属性，不是单纯DPS属性。"
  ]
}