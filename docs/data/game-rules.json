{
  "gameId": "abyss_echoes",
  "name": "深渊回响",
  "type": "loot_auto_battler_rpg",
  "partyRules": {
    "maxHeroes": 5,
    "positions": {
      "front": 2,
      "back": 3
    }
  },
  "heroRoles": [
    "tank",
    "physical_melee",
    "physical_ranged",
    "magic_ranged",
    "support"
  ],
  "combat": {
    "mode": "atb_tick_based_auto_battle",
    "ticksPerSecond": 10,
    "normalBattleSeconds": [
      10,
      20
    ],
    "eliteBattleSeconds": [
      20,
      40
    ],
    "bossBattleSeconds": [
      60,
      180
    ],
    "crit": {
      "baseCritChance": 0.05,
      "baseCritDamage": 1.5
    },
    "luckyHit": {
      "enabled": true,
      "description": "技能拥有基础幸运一击概率，触发装备、威能、被动效果。"
    },
    "cooldownReductionCap": 0.5,
    "damageFormula": "finalDamage = skillMultiplier * mainStat * critMultiplier * vulnerableMultiplier * additiveDamage * independentMultiplier * randomRoll",
    "speedSystem": {
      "enabled": true,
      "model": "ATB_TIME_AXIS",
      "atbMax": 100,
      "ticksPerSecond": 10,
      "atbGainFormula": "atbGainPerTick = speed * atbCoefficient",
      "atbCoefficient": 0.1,
      "overflow": true,
      "actionOnAtbFull": true,
      "actionResolution": [
        "atb_reaches_100",
        "choose_action_by_ai",
        "check_resource_and_cooldown",
        "start_cast_or_attack",
        "resolve_damage_and_effects",
        "keep_overflow_atb"
      ],
      "speedAttributes": {
        "speed": {
          "id": "speed",
          "name": "行动速度",
          "abbr": "SPD",
          "description": "决定行动条增长、先手和行动频率。"
        },
        "attackSpeed": {
          "id": "attackSpeed",
          "name": "攻击速度",
          "abbr": "ASP",
          "description": "决定普攻间隔与普攻触发频率。",
          "formula": "attackIntervalSeconds = 1 / attackSpeed"
        },
        "castSpeed": {
          "id": "castSpeed",
          "name": "施法速度",
          "abbr": "CSP",
          "description": "决定主动技能施法时间。",
          "formula": "finalCastTimeSeconds = baseCastTimeSeconds / castSpeed"
        }
      },
      "caps": {
        "speedMultiplierMin": 0.2,
        "attackSpeedMax": 3.0,
        "castSpeedMax": 3.0
      },
      "controlInteraction": {
        "freeze": "ATB停止增长，普攻计时和施法进度暂停。",
        "stun": "ATB可增长，但满条后无法行动；眩晕结束后立即重新判定。",
        "slow": "降低SPD。",
        "shock": "默认降低ASP；部分威能可改为额外雷击或行动条干扰。"
      }
    },
    "timelineLogPolicy": {
      "showOpeningOrder": true,
      "showAtbBreakpoints": false,
      "showOnlyImportantTriggers": true,
      "importantEvents": [
        "active_skill",
        "critical_hit",
        "lucky_hit",
        "death",
        "boss_phase",
        "control_applied",
        "legendary_aspect_triggered"
      ]
    }
  },
  "statuses": {
